<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zoctan.api.mapper.PsychologicalQuestionMapper">

    <resultMap id="PsychologicalQuestionResultMap" type="com.zoctan.api.entity.PsychologicalQuestion">
        <id property="id" column="id"/>
        <result property="testId" column="test_id"/>
        <result property="content" column="content"/>
        <result property="scoreMap" column="score_map"
                typeHandler="com.zoctan.api.core.typehandler.ScoreMapTypeHandler"/>
        <result property="options" column="options"
                typeHandler="com.zoctan.api.core.typehandler.OptionsListTypeHandler"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>

    <select id="selectByTestId" resultMap="PsychologicalQuestionResultMap">
        SELECT id, test_id, content, score_map, options, sort_order
        FROM psychological_question
        WHERE test_id = #{testId}
        ORDER BY sort_order
    </select>

</mapper>