<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zoctan.api.mapper.ConsultationSessionMapper">

    <resultMap id="BaseResultMap" type="com.zoctan.api.entity.ConsultationSession">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="counselor_id" property="counselorId"/>
        <result column="session_key_encrypted" property="sessionKeyEncrypted"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByUserIdAndCounselorId" resultMap="BaseResultMap">
        SELECT * FROM consultation_session
        WHERE user_id = #{userId} AND counselor_id = #{counselorId} AND status = 1
        ORDER BY created_at DESC LIMIT 1
    </select>

    <select id="findByUserId" resultType="com.zoctan.api.entity.ConsultationSession">
        SELECT *
        FROM consultation_session
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="findByUserIdOrCounselorId" resultType="ConsultationSession">
        SELECT *
        FROM consultation_session
        WHERE user_id = #{userId} OR counselor_id = #{userId}
    </select>
</mapper>