<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zoctan.api.mapper.PsychologicalTestMapper">

    <select id="selectAllTests" resultType="com.zoctan.api.entity.PsychologicalTest">
        SELECT id, title, description, total_questions AS totalQuestions
        FROM psychological_test
        ORDER BY id
    </select>

</mapper>